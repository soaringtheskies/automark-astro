---
import config from "../../src/config/config.json";
import "../../src/styles/main.css"; 
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NightcoreSkies | Coming Soon</title>
    <link rel="shortcut icon" href={config.site.favicon} />
  </head>
  <body class="bg-body flex items-center justify-center min-h-screen text-white overflow-hidden">
    
    <!-- Background Glow -->
    <div class="absolute inset-0 grid place-items-center -z-10">
      <div class="size-150 bg-radial from-primary-light/20 to-transparent rounded-full blur-3xl"></div>
    </div>

    <main class="text-center px-4 relative z-10">
      <div class="mb-12 flex justify-center">
        <img src={config.site.logo} alt="NightcoreSkies" width="200" class="h-auto" />
      </div>
      
      <h1 class="text-5xl md:text-7xl font-bold mb-6 tracking-tight">
        The Skies are <span class="text-primary">Clearing...</span>
      </h1>
      
      <p class="text-xl md:text-2xl text-text-dark max-w-2xl mx-auto mb-10">
        I'm currently migrating the music archives and hardware tier lists. 
        Stick around—the full experience is launching soon.
      </p>

      <div class="flex gap-4 justify-center">
        <a href={`mailto:${config.params.footer_email}`} class="btn btn-outline">
          Get in Touch
        </a>
      </div>
    </main>

  </body>
</html>